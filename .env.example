VECTORIZER_API_ID=
VECTORIZER_API_TOKEN=
# 'production' (default) requires a paid Vectorizer.ai API subscription.
# Set to 'test' for dev — free, watermarked output, full structure for verification.
VECTORIZER_MODE=production
MAX_FILE_SIZE_MB=20
OUTPUT_DPI=300
TEMP_DIR=/tmp/djs-art-engine
DJ_BASIC_USER=
DJ_BASIC_PASS=
# Claude vision quality-check (claude-haiku-4-5 by default). Leave blank to disable.
ANTHROPIC_API_KEY=
QC_MODEL=claude-haiku-4-5
# Kill-switch — set to false to skip the Claude QC stage (memory panic switch).
QC_ENABLED=true

# Real-ESRGAN AI upscaling via Replicate, used when source < 1024x800.
# Get a token at https://replicate.com/account/api-tokens. Leave blank to disable.
REPLICATE_API_TOKEN=
UPSCALE_ENABLED=true
